Algoritmo "Sucessor"
// Disciplina   : [Linguagem e Lµgica de ProgramaÓÐo]
// Professor   : Jailson
// DescriÓÐo   : Aqui vocõ descreve o que o programa faz! (funÓÐo)
// Autor(a)    : Alisson da Silva Dutra
// Data atual  : 14/03/2024
Var
num,antecessor:inteiro

Inicio
     Escreval("Digite um numero inteiro")
     leia(num)
     antecessor <- num - 1
     Escreva ("Antecessor,", num, " Õ ", antecessor)

Fimalgoritmo